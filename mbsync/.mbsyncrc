IMAPAccount gmail
Host imap.gmail.com
UserCmd "echo $PERSONAL_GMAIL"
PassCmd "gpg --quiet --decrypt $HOME/.password-store/auth-sources/mbsync/password.gpg"
TLSType IMAPS
TLSVersions +1.3
AuthMechs LOGIN
CertificateFile /opt/homebrew/etc/openssl@1.1/cert.pem

MaildirStore gmail-local
Subfolders Verbatim
Path ~/Mail/
Inbox ~/Mail/Inbox

IMAPStore gmail-remote
Account gmail

# https://github.com/danielfleischer/mu4easy
# 
# See also bin/mbsync-parallel (in this repo) for a bash script to check the
# different email channels in parallel (thereby speeding up the process)
Channel gmail-inbox
Far :gmail-remote:"INBOX"
Near :gmail-local:"INBOX"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel gmail-daily
Far :gmail-remote:"Daily"
Near :gmail-local:"Daily"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel gmail-refiled
Far :gmail-remote:"Refiled"
Near :gmail-local:"Refiled"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel gmail-starred
Far :gmail-remote:"[Gmail]/Starred"
Near :gmail-local:"Starred"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel gmail-sent
Far :gmail-remote:"[Gmail]/Sent Mail"
Near :gmail-local:"Sent"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel gmail-trash
Far :gmail-remote:"[Gmail]/Trash"
Near :gmail-local:"Trash"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel gmail-all
Far :gmail-remote:"[Gmail]/All Mail"
Near :gmail-local:"All"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Group gmail
Channel gmail-inbox
Channel gmail-daily
Channel gmail-refiled
Channel gmail-sent
Channel gmail-trash
Channel gmail-starred

Group gmail-all
Channel gmail-inbox
Channel gmail-daily
Channel gmail-sent
Channel gmail-trash
Channel gmail-starred
Channel gmail-all

# Epoch AI (Google Workspace, via email-oauth2-proxy)
IMAPAccount epoch
Host 127.0.0.1
Port 2993
UserCmd "echo $EPOCH_EMAIL"
PassCmd "echo oauth2-proxy"
TLSType None
AuthMechs LOGIN

MaildirStore epoch-local
Subfolders Verbatim
Path ~/Mail/epoch/
Inbox ~/Mail/epoch/Inbox

IMAPStore epoch-remote
Account epoch

Channel epoch-inbox
Far :epoch-remote:"INBOX"
Near :epoch-local:"INBOX"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel epoch-sent
Far :epoch-remote:"[Gmail]/Sent Mail"
Near :epoch-local:"Sent"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel epoch-trash
Far :epoch-remote:"[Gmail]/Trash"
Near :epoch-local:"Trash"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel epoch-starred
Far :epoch-remote:"[Gmail]/Starred"
Near :epoch-local:"Starred"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Channel epoch-all
Far :epoch-remote:"[Gmail]/All Mail"
Near :epoch-local:"All"
CopyArrivalDate yes
Create Both
Expunge Both
SyncState *

Group epoch
Channel epoch-inbox
Channel epoch-sent
Channel epoch-trash
Channel epoch-starred

Group epoch-all
Channel epoch-inbox
Channel epoch-sent
Channel epoch-trash
Channel epoch-starred
Channel epoch-all