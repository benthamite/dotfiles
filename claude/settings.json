{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Task",
      "Glob",
      "Grep",
      "NotebookEdit"
    ]
  },
  "model": "opus",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/emacs-profiles/7.1.29-target/elpaca/repos/claude-code/bin/claude-code-hook-wrapper stop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/emacs-profiles/7.1.29-target/elpaca/repos/dotfiles/emacs/extras/etc/claude-code-statusline.sh",
    "padding": 0
  }
}
