#!/usr/bin/env python3
"""Compatibility wrapper for opening URLs with the Trajectory Chrome profile."""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path


ALIAS = "trajectory"


def _forward_args(argv: list[str]) -> list[str]:
    args = list(argv)
    if "--setup" in args:
        index = args.index("--setup")
        if index == len(args) - 1 or args[index + 1].startswith("-"):
            args.insert(index + 1, ALIAS)
        return args
    return [ALIAS, *args]


def main(argv: list[str] | None = None) -> int:
    opener = Path(__file__).resolve().with_name("chrome-profile-open")
    forwarded = _forward_args(list(sys.argv[1:] if argv is None else argv))
    proc = subprocess.run([str(opener), *forwarded], text=True)
    return proc.returncode


if __name__ == "__main__":
    raise SystemExit(main())
