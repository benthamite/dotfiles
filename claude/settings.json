{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Task",
      "Glob",
      "Grep",
      "NotebookEdit",
      "mcp__slack-epochai__slack_read_channel",
      "mcp__slack-epochai__slack_read_thread",
      "mcp__slack-epochai__slack_read_user_profile",
      "mcp__slack-epochai__slack_read_canvas",
      "mcp__slack-epochai__slack_search_channels",
      "mcp__slack-epochai__slack_search_public",
      "mcp__slack-epochai__slack_search_public_and_private",
      "mcp__slack-epochai__slack_search_users"
    ]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/My\\ Drive/dotfiles/claude/hooks/require-elisp-test-before-commit.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/My\\ Drive/dotfiles/claude/hooks/track-elisp-test.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/My\\ Drive/dotfiles/claude/hooks/symlink-project-memory.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your attention\" with title \"Claude Code\"'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.config/emacs-profiles/7.1.30-target/elpaca/repos/claude-code/bin/claude-code-hook-wrapper stop"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/emacs-profiles/7.1.30-target/elpaca/repos/dotfiles/emacs/extras/etc/claude-code-statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "slack@claude-plugins-official": true
  },
  "theme": "dark",
  "effortLevel": "high",
  "mcpServers": {
    "home-assistant": {
      "command": "mcp-proxy",
      "env": {
        "SSE_URL": "http://homeassistant.local:8123/mcp_server/sse"
      }
    }
  }
}