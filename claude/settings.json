{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "Task",
      "Glob",
      "Grep",
      "NotebookEdit",
      "mcp__*"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/My\\ Drive/dotfiles/claude/hooks/require-elisp-test-before-commit.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/My\\ Drive/dotfiles/claude/hooks/require-readme-update.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "~/My\\ Drive/dotfiles/claude/hooks/require-doc-update.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/My\\ Drive/dotfiles/claude/hooks/track-elisp-test.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/My\\ Drive/dotfiles/claude/hooks/symlink-project-memory.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "~/My\\ Drive/dotfiles/claude/hooks/load-elisp-after-edit.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "Notification": [],
    "Stop": []
  },
  "statusLine": {
    "type": "command",
    "command": "~/My\\ Drive/dotfiles/emacs/extras/etc/claude-code-statusline.sh",
    "padding": 0
  },
  "effortLevel": "high",
  "defaultMode": "bypassPermissions",
  "theme": "dark",
  "mcpServers": {},
  "skipDangerousModePermissionPrompt": true
}