#!/bin/bash
# Wrapper to launch Emacs.app with profile support and suppress glib warning

EMACS_BIN="/Applications/Emacs.app/Contents/MacOS/Emacs"
PROFILES_DIR="$HOME/.config/emacs-profiles"
PROFILE=""
ARGS=()

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -p|--profile)
            PROFILE="$2"
            shift 2
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# Filter out the GNotificationCenterDelegate warning from stderr
filter_stderr() {
    grep -v "Class GNotificationCenterDelegate is implemented in both"
}

# Launch Emacs, filtering the duplicate class warning
if [[ -n "$PROFILE" ]]; then
    "$EMACS_BIN" --init-directory="$PROFILES_DIR/$PROFILE" "${ARGS[@]}" 2> >(filter_stderr >&2)
else
    "$EMACS_BIN" "${ARGS[@]}" 2> >(filter_stderr >&2)
fi
