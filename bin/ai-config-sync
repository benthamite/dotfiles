def usage() -> None:
    print(
        """Usage: ai-config-sync MODE

Modes:
  remind-claude   Read Claude hook JSON from stdin and print counterpart reminders.
  remind-codex    Read Codex hook JSON from stdin and print counterpart reminders.
  guard-commit    Read Bash PreToolUse JSON from stdin and block one-sided commits.
  audit           Check the local Claude/Codex config inventory and content drift.
  migrate-project-instructions [ROOT...]
                  Create missing sibling AGENTS.md files from project CLAUDE.md files.
""",
        end="",
    )


def read_input_json() -> dict:
    raw = sys.stdin.read()
    if not raw.strip():
        return {}
    return json.loads(raw)


def run_git(args: list[str], repo: Path = ROOT) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        ["git", "-C", str(repo), *args],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )


def git_lines(args: list[str], repo: Path = ROOT) -> list[str]:
    proc = run_git(args, repo)
    if proc.returncode != 0:
        return []
    return [line for line in proc.stdout.splitlines() if line]


def real_path(path: Path) -> Path:
    try:
        return path.resolve()
    except OSError:
        return Path(os.path.realpath(path))


def same_path(left: Path, right: Path) -> bool:
    return real_path(left) == real_path(right)


def nearest_existing_path(path: Path) -> Path:
    candidate = path if path.is_dir() else path.parent
    while not candidate.exists() and candidate != candidate.parent:
        candidate = candidate.parent
    return candidate


def git_root_for_dir(path: Path) -> Path | None:
    proc = subprocess.run(
        ["git", "-C", str(path), "rev-parse", "--show-toplevel"],
        check=False,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    if proc.returncode != 0:
        return None
    return Path(proc.stdout.strip())


def git_root_for_path(path: Path, fallback_cwd: Path | None = None) -> Path | None:
    root = git_root_for_dir(nearest_existing_path(path))
    if root is not None:
        return root
    if fallback_cwd is not None:
        return git_root_for_dir(nearest_existing_path(fallback_cwd))
    return None


def path_from_token(token: str, cwd: Path | None = None) -> Path:
    if cwd is None:
        cwd = Path.cwd()
    expanded = os.path.expanduser(token)
    path = Path(expanded)
    if not path.is_absolute():
        path = cwd / path
    return path


def tool_input_object(data: dict) -> dict:
    tool_input = data.get("tool_input") or {}
    if isinstance(tool_input, dict):
        return tool_input
    if isinstance(tool_input, str):
        try:
            parsed = json.loads(tool_input)
        except json.JSONDecodeError:
            return {"command": tool_input}
        if isinstance(parsed, dict):
            return parsed
        return {"command": tool_input}
    return {}


def relative_to_repo(path_text: str, cwd: Path, repo_root: Path) -> str:
    if not path_text:
        return ""
    if path_text in {".", ""}:
        return path_text

    path = path_from_token(path_text, cwd)
    try:
        return path.relative_to(repo_root).as_posix()
    except ValueError:
        pass

    try:
        return real_path(path).relative_to(real_path(repo_root)).as_posix()
    except ValueError:
        return ""


def local_sync_path(rel: str) -> bool:
    return Path(rel).name in {"CLAUDE.md", "AGENTS.md"} or rel.startswith((".claude/", ".codex/"))


def global_sync_path(rel: str) -> bool:
    return (
        rel.startswith(("claude/", "codex/"))
        or rel == MANIFEST
        or rel in SYNC_CONFIG_PATHS
        or rel in {GLOBAL_INSTRUCTION_CLAUDE, GLOBAL_INSTRUCTION_CODEX}
    )


def sync_scope_for_path(
    path_text: str,
    cwd: Path | None = None,
    repo_root: Path | None = None,
) -> tuple[str, Path | None, str]:
    if not path_text:
        return "other", None, ""
    if cwd is None:
        cwd = Path.cwd()

    path = path_from_token(path_text, cwd)
    home = Path.home()
    if path == home / ".claude" / "settings.json":
        return "global", ROOT, str(path)
    if path == home / ".claude" / "settings.local.json":
        return "global", ROOT, str(path)

    root_real = real_path(ROOT)
    try:
        root_rel = real_path(path).relative_to(root_real).as_posix()
    except ValueError:
        root_rel = ""
    if root_rel and global_sync_path(root_rel):
        return "global", ROOT, root_rel

    local_root = repo_root or git_root_for_path(path, cwd)
    if local_root is None:
        return "other", None, path_text
    rel = relative_to_repo(path_text, cwd, local_root)
    if local_sync_path(rel):
        return "local", local_root, rel

    return "other", local_root, rel or path_text


def hook_cwd(data: dict) -> Path:
    tool_input = tool_input_object(data)
    for source in (tool_input, data):
        for key in ("cwd", "workdir", "working_dir"):
            value = source.get(key)
            if value:
                return path_from_token(str(value))
    return Path.cwd()


def direct_file_path(data: dict) -> str:
    tool_input = tool_input_object(data)
    for key in ("file_path", "filePath", "path", "notebook_path"):
        value = tool_input.get(key)
        if value:
            return str(value)
    return ""


def patch_text(data: dict) -> str:
    tool_input = tool_input_object(data)
    for key in ("patch", "command", "input", "text"):
        value = tool_input.get(key)
        if value:
            return str(value)
    return ""


def paths_from_patch(text: str) -> list[str]:
    paths: list[str] = []
    for line in text.splitlines():
        for prefix in (
            "*** Add File: ",
            "*** Update File: ",
            "*** Delete File: ",
            "*** Move to: ",
        ):
            if line.startswith(prefix):
                paths.append(line.removeprefix(prefix))
                break
        else:
            if line.startswith("diff --git a/"):
                parts = line.split()
                if len(parts) >= 4:
                    old = parts[2].removeprefix("a/")
                    new = parts[3].removeprefix("b/")
                    if old != "/dev/null":
                        paths.append(old)
                    if new != "/dev/null":
                        paths.append(new)
    return paths


def paths_from_codex_input(data: dict) -> list[str]:
    paths: list[str] = []
    direct = direct_file_path(data)
    if direct:
        paths.append(direct)
    patch = patch_text(data)
    if patch:
        paths.extend(paths_from_patch(patch))
    return paths


def global_sync_message_for_path(rel: str) -> str:
    if not rel:
        return ""

    home = str(Path.home())
    if rel.startswith("claude/skills/"):
        skill = rel.removeprefix("claude/skills/").split("/", 1)[0]
        return f"claude/skills/{skill} changed; update codex/skills/{skill} in the same session."
    if rel.startswith("codex/skills/"):
        skill = rel.removeprefix("codex/skills/").split("/", 1)[0]
        return f"codex/skills/{skill} changed; update claude/skills/{skill} in the same session."
    if rel.startswith("claude/hooks/"):
        hook = rel.removeprefix("claude/hooks/")
        if (ROOT / "codex" / "hooks" / hook).exists():
            return f"claude/hooks/{hook} changed; update codex/hooks/{hook} and the hook registration if needed."
        return f"claude/hooks/{hook} changed; add/adjust its Codex counterpart or record why it is unsupported in {MANIFEST}."
    if rel.startswith("codex/hooks/"):
        hook = rel.removeprefix("codex/hooks/")
        if (ROOT / "claude" / "hooks" / hook).exists():
            return f"codex/hooks/{hook} changed; update claude/hooks/{hook} and ~/.claude/settings.json if registration changed."
        return f"codex/hooks/{hook} changed; add/adjust its Claude counterpart or record why it is Codex-only in {MANIFEST}."
    if rel in {f"{home}/.claude/settings.json", f"{home}/.claude/settings.local.json"}:
        return f"{rel} changed; check codex/hooks.json, codex/config.toml, codex/rules/default.rules, and {MANIFEST} for matching policy changes."
    if rel == "codex/hooks.json":
        return f"codex/hooks.json changed; update ~/.claude/settings.json and {MANIFEST} if the global hook policy changed."
    if rel == "codex/config.toml":
        return f"codex/config.toml changed; update {MANIFEST} if instruction, skill, or hook registration changed."
    if rel == "codex/rules/default.rules":
        return f"codex/rules/default.rules changed; update {MANIFEST} if the Codex-only policy changed."
    if rel == GLOBAL_INSTRUCTION_CLAUDE:
        return f"{GLOBAL_INSTRUCTION_CLAUDE} changed; update {GLOBAL_INSTRUCTION_CODEX} in the same session."
    if rel == GLOBAL_INSTRUCTION_CODEX:
        return f"{GLOBAL_INSTRUCTION_CODEX} changed; update {GLOBAL_INSTRUCTION_CLAUDE} in the same session."
    return ""


def local_sync_message_for_path(rel: str, repo_root: Path) -> str:
    if not rel:
        return ""

    if Path(rel).name == "CLAUDE.md":
        counterpart = Path(rel).with_name("AGENTS.md").as_posix()
        return f"Project-local {rel} changed; update {counterpart} in the same repo."
    if Path(rel).name == "AGENTS.md":
        counterpart = Path(rel).with_name("CLAUDE.md").as_posix()
        return f"Project-local {rel} changed; update {counterpart} in the same repo."
    if rel.startswith(".claude/skills/"):
        skill = rel.removeprefix(".claude/skills/").split("/", 1)[0]
        return (
            f"Project-local .claude/skills/{skill} changed; "
            f"update .codex/skills/{skill} in the same repo."
        )
    if rel.startswith(".codex/skills/"):
        skill = rel.removeprefix(".codex/skills/").split("/", 1)[0]
        return (
            f"Project-local .codex/skills/{skill} changed; "
            f"update .claude/skills/{skill} in the same repo."
        )
    if rel.startswith(".claude/hooks/"):
        hook = rel.removeprefix(".claude/hooks/")
        if (repo_root / ".codex" / "hooks" / hook).exists():
            return (
                f"Project-local .claude/hooks/{hook} changed; "
                f"update .codex/hooks/{hook} and .codex/hooks.json if registration changed."
            )
        return (
            f"Project-local .claude/hooks/{hook} changed; "
            "add/adjust its Codex counterpart under .codex/hooks/."
        )
    if rel.startswith(".codex/hooks/"):
        hook = rel.removeprefix(".codex/hooks/")
        if (repo_root / ".claude" / "hooks" / hook).exists():
            return (
                f"Project-local .codex/hooks/{hook} changed; "
                f"update .claude/hooks/{hook} and .claude/settings.json if registration changed."
            )
        return (
            f"Project-local .codex/hooks/{hook} changed; "
            "add/adjust its Claude counterpart under .claude/hooks/."
        )
    if rel in {".claude/settings.json", ".claude/settings.local.json"}:
        return (
            f"Project-local {rel} changed; "
            "check .codex/hooks.json and .codex/config.toml for matching policy changes."
        )
    if rel == ".codex/hooks.json":
        return (
            "Project-local .codex/hooks.json changed; "
            "update .claude/settings.json if the local hook policy changed."
        )
    if rel == ".codex/config.toml":
        return (
            "Project-local .codex/config.toml changed; "
            "update the Claude project config if instruction, skill, or hook policy changed."
        )
    if rel == ".codex/rules/default.rules":
        return (
            "Project-local .codex/rules/default.rules changed; "
            "update the Claude project config if the local policy changed."
        )
    return ""


def reminder_messages(paths: Iterable[str], cwd: Path | None = None) -> list[str]:
    messages = set()
    for path in paths:
        if not path:
            continue
        kind, root, rel = sync_scope_for_path(path, cwd)
        if kind == "global":
            messages.add(global_sync_message_for_path(rel))
        elif kind == "local" and root is not None:
            messages.add(local_sync_message_for_path(rel, root))
    return sorted(message for message in messages if message)


def print_reminders(paths: Iterable[str], cwd: Path | None = None) -> None:
    for message in reminder_messages(paths, cwd):
        print(message)


def print_codex_post_tool_message(messages: Iterable[str]) -> None:
    text = "\n".join(message for message in messages if message)
    if not text:
        return
    print(
        json.dumps(
            {
                "hookSpecificOutput": {
                    "hookEventName": "PostToolUse",
                    "additionalContext": text,
                }
            },
            indent=2,
        )
    )


def remind_claude() -> None:
    data = read_input_json()
    path = direct_file_path(data)
    if path:
        print_reminders([path], hook_cwd(data))


def remind_codex() -> None:
    data = read_input_json()
    print_codex_post_tool_message(reminder_messages(paths_from_codex_input(data), hook_cwd(data)))


def shell_tokens(command: str) -> list[str]:
    lexer = shlex.shlex(command, posix=True, punctuation_chars=True)
    lexer.whitespace_split = True
    return list(lexer)


def split_shell_segments(tokens: list[str]) -> list[list[str]]:
    segments: list[list[str]] = []
    current: list[str] = []
    for token in tokens:
        if set(token) <= {"&", "|", ";", "(", ")"}:
            if current:
                segments.append(current)
                current = []
            continue
        current.append(token)
    if current:
        segments.append(current)
    return segments


def git_invocation(segment: list[str], cwd: Path) -> tuple[str, list[str], Path] | None:
    if not segment or Path(segment[0]).name != "git":
        return None

    args = segment[1:]
    git_cwd = cwd
    i = 0
    while i < len(args):
        arg = args[i]
        if arg == "-C" and i + 1 < len(args):
            git_cwd = path_from_token(args[i + 1], git_cwd)
            i += 2
            continue
        if arg.startswith("-C") and len(arg) > 2:
            git_cwd = path_from_token(arg[2:], git_cwd)
            i += 1
            continue
        if arg in GIT_OPTIONS_WITH_VALUE:
            i += 2
            continue
        if arg.startswith("-"):
            i += 1
            continue
        return arg, args[i + 1 :], git_cwd
    return None


def dirty_paths(
    repo: Path = ROOT,
    include_untracked: bool = True,
    include_tracked: bool = True,
) -> set[str]:
    paths: set[str] = set()
    if include_tracked:
        paths.update(git_lines(["diff", "--name-only"], repo))
        paths.update(git_lines(["diff", "--cached", "--name-only"], repo))
    if include_untracked:
        paths.update(git_lines(["ls-files", "--others", "--exclude-standard"], repo))
    return paths


def staged_paths(repo: Path = ROOT) -> set[str]:
    return set(git_lines(["diff", "--cached", "--name-only"], repo))


def git_text(args: list[str], repo: Path = ROOT) -> str | None:
    proc = run_git(args, repo)
    if proc.returncode != 0:
        return None
    return proc.stdout


def tracked_dirty_paths(repo: Path = ROOT) -> set[str]:
    return set(git_lines(["diff", "--name-only"], repo))


def path_has_change(path: str, changed: set[str]) -> bool:
    if path in changed:
        return True
    prefix = path.rstrip("/") + "/"
    return any(item.startswith(prefix) for item in changed)


def expand_pathspec(rel: str, changed: set[str]) -> set[str]:
    if rel in {".", ""}:
        return set(changed)
    if path_has_change(rel, changed):
        prefix = rel.rstrip("/") + "/"
        expanded = {item for item in changed if item == rel or item.startswith(prefix)}
        return expanded or {rel}
    return {rel}


def paths_from_git_add(
    args: list[str],
    git_cwd: Path,
    repo_root: Path,
    changed: set[str],
) -> set[str]:
    paths: set[str] = set()
    include_all = False
    include_tracked = False
    pathspec_from_file = False
    i = 0

    while i < len(args):
        arg = args[i]
        if arg == "--":
            i += 1
            break
        if arg in {"-A", "--all", "--no-ignore-removal"}:
            include_all = True
            i += 1
            continue
        if arg in {"-u", "--update"}:
            include_tracked = True
            i += 1
            continue
        if arg in GIT_ADD_OPTIONS_WITH_VALUE:
            pathspec_from_file = True
            i += 2
            continue
        if arg.startswith("--pathspec-from-file="):
            pathspec_from_file = True
            i += 1
            continue
        if arg.startswith("-"):
            i += 1
            continue
        break

    if include_all or pathspec_from_file:
        return set(changed)
    if include_tracked and i >= len(args):
        return tracked_dirty_paths(repo_root)

    for raw_path in args[i:]:
        rel = relative_to_repo(raw_path, git_cwd, repo_root)
        if rel and not rel.startswith("/"):
            paths.update(expand_pathspec(rel, changed))
    if include_tracked:
        paths.update(tracked_dirty_paths(repo_root))
    return paths


def is_commit_all_arg(arg: str) -> bool:
    if arg == "--all":
        return True
    return arg.startswith("-") and not arg.startswith("--") and "a" in arg[1:]


def command_paths_and_commit_repos(
    command: str,
    cwd: Path,
) -> tuple[dict[Path, set[str]], set[Path]]:
    try:
        tokens = shell_tokens(command)
    except ValueError:
        repo = git_root_for_dir(nearest_existing_path(cwd))
        if repo is not None and "git commit" in command:
            return {}, {repo}
        return {}, set()

    current_dir = cwd
    paths_by_repo: dict[Path, set[str]] = {}
    commit_repos: set[Path] = set()
    dirty_cache: dict[Path, set[str]] = {}

    def repo_dirty(repo: Path) -> set[str]:
        if repo not in dirty_cache:
            dirty_cache[repo] = dirty_paths(repo)
        return dirty_cache[repo]

    for segment in split_shell_segments(tokens):
        if segment and segment[0] == "cd" and len(segment) >= 2:
            current_dir = path_from_token(segment[1], current_dir)
            continue

        invocation = git_invocation(segment, current_dir)
        if invocation is None:
            continue

        command_name, args, git_cwd = invocation
        repo = git_root_for_dir(nearest_existing_path(git_cwd))
        if repo is None:
            continue
        if command_name == "add":
            paths_by_repo.setdefault(repo, set()).update(
                paths_from_git_add(args, git_cwd, repo, repo_dirty(repo))
            )
        elif command_name == "commit":
            commit_repos.add(repo)
            if any(is_commit_all_arg(arg) for arg in args):
                paths_by_repo.setdefault(repo, set()).update(tracked_dirty_paths(repo))

    return paths_by_repo, commit_repos


def skip_runtime_path(path: str) -> bool:
    return any(fnmatch.fnmatchcase(path, pattern) for pattern in RUNTIME_PATTERNS)


def has_changed_prefix(prefix: str, paths: set[str], changed: set[str]) -> bool:
    prefix = prefix.rstrip("/") + "/"
    for path in paths:
        if path.startswith(prefix) and path_has_change(path, changed):
            return True
    return False


def parse_manifest_text(text: str, label: str, problems: list[str]) -> dict:
    try:
        return json.loads(text)
    except json.JSONDecodeError as exc:
        problems.append(f"{label} is not valid JSON: {exc}")
        return {}


def manifest_text_from_head() -> str:
    text = git_text(["show", f"HEAD:{MANIFEST}"])
    if text is not None:
        return text
    if MANIFEST_PATH.exists():
        return MANIFEST_PATH.read_text()
    return "{}"


def guard_manifests(
    command_paths: set[str],
    staged: set[str],
    problems: list[str],
) -> tuple[dict, dict]:
    base_text = manifest_text_from_head()
    base = parse_manifest_text(base_text, f"HEAD:{MANIFEST}", problems)

    if path_has_change(MANIFEST, command_paths):
        candidate_text = MANIFEST_PATH.read_text()
        label = MANIFEST
    elif path_has_change(MANIFEST, staged):
        candidate_text = git_text(["show", f":{MANIFEST}"])
        if candidate_text is None:
            problems.append(f"Could not read staged {MANIFEST}")
            candidate_text = base_text
        label = f"staged {MANIFEST}"
    else:
        candidate_text = base_text
        label = f"HEAD:{MANIFEST}"

    candidate = parse_manifest_text(candidate_text, label, problems)
    return base, candidate


def manifest_item_by_name(manifest: dict, section: str, name: str) -> dict | None:
    for item in manifest.get(section) or []:
        if item.get("name") == name:
            return item
    return None


def manifest_registration(manifest: dict, path: str) -> dict | None:
    for item in manifest.get("registrations") or []:
        if item.get("path") == path:
            return item
    return None


def manifest_item_is_paired(item: dict | None) -> bool:
    if not item:
        return False
    status = str(item.get("status") or "")
    return bool(item.get("claude") and item.get("codex") and status.startswith(PEER_STATUS_PREFIXES))


def manifest_item_is_registered_pair(item: dict | None) -> bool:
    if not item:
        return False
    return bool(item.get("claude") and item.get("codex") and item.get("status") in REGISTERED_PAIR_STATUSES)


def manifest_item_is_explicitly_unpaired(item: dict | None) -> bool:
    if not item:
        return False
    status = str(item.get("status") or "")
    return bool(status) and not status.startswith(PEER_STATUS_PREFIXES)


def manifest_registration_changed(base: dict, candidate: dict, path: str) -> bool:
    return manifest_registration(base, path) != manifest_registration(candidate, path)


def manifest_item_changed(base: dict, candidate: dict, section: str, name: str) -> bool:
    return manifest_item_by_name(base, section, name) != manifest_item_by_name(candidate, section, name)


def manifest_skill_removed(base: dict, candidate: dict, skill: str) -> bool:
    return (
        manifest_item_by_name(base, "skills", skill) is not None
        and manifest_item_by_name(candidate, "skills", skill) is None
    )


def global_skill_files_absent(skill: str) -> bool:
    return not (ROOT / "claude" / "skills" / skill / "SKILL.md").exists() and not (
        ROOT / "codex" / "skills" / skill / "SKILL.md"
    ).exists()


def skill_sync_problems(skill: str) -> list[str]:
    problems: list[str] = []
    claude_dir = ROOT / "claude" / "skills" / skill
    codex_dir = ROOT / "codex" / "skills" / skill
    claude_skill = claude_dir / "SKILL.md"
    codex_skill = codex_dir / "SKILL.md"

    if not claude_skill.exists():
        problems.append(f"Missing Claude skill file: claude/skills/{skill}/SKILL.md")
    if not codex_skill.exists():
        problems.append(f"Missing Codex skill file: codex/skills/{skill}/SKILL.md")
    if problems:
        return problems

    if normalized_skill_text(claude_skill) != normalized_skill_text(codex_skill):
        problems.append(f"Skill content drift after tool-specific frontmatter normalization: {skill}")

    claude_aux = skill_aux_files(claude_dir)
    codex_aux = skill_aux_files(codex_dir)
    for rel in sorted(set(claude_aux) - set(codex_aux)):
        problems.append(f"Auxiliary skill file only in Claude tree: {skill}/{rel}")
    for rel in sorted(set(codex_aux) - set(claude_aux)):
        problems.append(f"Auxiliary skill file only in Codex tree: {skill}/{rel}")
    for rel in sorted(set(claude_aux) & set(codex_aux)):
        if not filecmp.cmp(claude_aux[rel], codex_aux[rel], shallow=False):
            problems.append(f"Auxiliary skill file drift: {skill}/{rel}")

    return problems


def local_skill_sync_problems(repo_root: Path, skill: str, skill_root: str = "skills") -> list[str]:
    problems: list[str] = []
    claude_dir = repo_root / ".claude" / skill_root / skill
    codex_dir = repo_root / ".codex" / skill_root / skill
    claude_skill = claude_dir / "SKILL.md"
    codex_skill = codex_dir / "SKILL.md"

    if not claude_skill.exists():
        problems.append(
            f"Missing Claude project-local skill file: .claude/{skill_root}/{skill}/SKILL.md"
        )
    if not codex_skill.exists():
        problems.append(
            f"Missing Codex project-local skill file: .codex/{skill_root}/{skill}/SKILL.md"
        )
    if problems:
        return problems

    if normalized_skill_text(claude_skill) != normalized_skill_text(codex_skill):
        problems.append(
            f"Project-local skill content drift after tool-specific frontmatter normalization: {skill}"
        )

    claude_aux = skill_aux_files(claude_dir)
    codex_aux = skill_aux_files(codex_dir)
    for rel in sorted(set(claude_aux) - set(codex_aux)):
        problems.append(f"Auxiliary project-local skill file only in Claude tree: {skill}/{rel}")
    for rel in sorted(set(codex_aux) - set(claude_aux)):
        problems.append(f"Auxiliary project-local skill file only in Codex tree: {skill}/{rel}")
    for rel in sorted(set(claude_aux) & set(codex_aux)):
        if not filecmp.cmp(claude_aux[rel], codex_aux[rel], shallow=False):
            problems.append(f"Auxiliary project-local skill file drift: {skill}/{rel}")

    return problems


def local_skill_readme_problems(
    changed_paths: set[str],
    skill: str,
    skill_root: str,
) -> list[str]:
    if path_has_change("README.org", changed_paths):
        return []
    return [
        f"Project-local {skill_root}/{skill} changed without README.org documentation in the same repo. Update the local README.org Skills section, and document only this repo's local skill behavior; do not describe the other agent's paths or behavior there."
    ]


def normalized_project_instruction_text(path: Path) -> str:
    text = path.read_text()
    text = re.sub(r"(?m)^@(\S+)[ \t]*$", r"`\1`", text)
    return "\n".join(line.rstrip() for line in text.splitlines()).strip() + "\n"


def codex_project_instruction_text_from_claude(path: Path) -> str:
    text = path.read_text()
    text = re.sub(r"(?m)^@(\S+)[ \t]*$", r"`\1`", text)
    if not text.endswith("\n"):
        text += "\n"
    return text


def local_instruction_sync_problems(repo_root: Path, rel_dir: str = ".") -> list[str]:
    problems: list[str] = []
    base_dir = repo_root if rel_dir in {"", "."} else repo_root / rel_dir
    claude_path = base_dir / "CLAUDE.md"
    codex_path = base_dir / "AGENTS.md"
    claude_rel = claude_path.relative_to(repo_root).as_posix()
    codex_rel = codex_path.relative_to(repo_root).as_posix()

    if not claude_path.exists() and not codex_path.exists():
        return problems
    if not claude_path.exists():
        problems.append(f"Missing project-local instruction file: {claude_rel}")
    if not codex_path.exists():
        problems.append(f"Missing project-local instruction file: {codex_rel}")
    if problems:
        return problems

    if normalized_project_instruction_text(claude_path) != normalized_project_instruction_text(codex_path):
        problems.append(
            f"Project-local instruction drift after tool-specific normalization: {claude_rel} / {codex_rel}"
        )
    return problems


def normalized_global_instruction_text(path: Path) -> str:
    text = path.read_text()
    root_text = str(ROOT)
    text = text.replace("# Global Claude Code conventions", "# Global agent conventions")
    text = text.replace("# Global Codex conventions", "# Global agent conventions")
    text = text.replace(f"{root_text}/", "")
    text = text.replace("`claude/context/mcp-servers.md`", "`context/mcp-servers.md`")
    text = text.replace("`claude/context/google-services.md`", "`context/google-services.md`")
    text = text.replace("`claude/context/secrets.md`", "`context/secrets.md`")
    codex_secrets_rule = (
        "- **Secrets:** Read `context/secrets.md` before handling secrets. "
        "In particular, never echo or print secrets from `pass`, `.zshenv-secrets`, or MCP credential resolution; "
        "use full `pass` paths and `pass find`, not `pass ls` grep."
    )
    text = text.replace(codex_secrets_rule, "- @context/secrets.md")
    return text


def global_instruction_sync_problems() -> list[str]:
    problems: list[str] = []
    codex_path = ROOT / GLOBAL_INSTRUCTION_CODEX
    if not (ROOT / GLOBAL_INSTRUCTION_CLAUDE).exists():
        problems.append(f"Missing Claude global instruction file: {GLOBAL_INSTRUCTION_CLAUDE}")
    if not codex_path.exists():
        problems.append(f"Missing Codex global instruction file: {GLOBAL_INSTRUCTION_CODEX}")
    if problems:
        return problems

    if normalized_global_instruction_text(ROOT / GLOBAL_INSTRUCTION_CLAUDE) != normalized_global_instruction_text(codex_path):
        problems.append("Global instruction semantic drift after tool-specific normalization.")
    actual_codex = codex_path.read_text()
    for forbidden in ("@context/", "`context/"):
        if forbidden in actual_codex:
            problems.append(f"Codex global instructions contain unresolved relative context reference: {forbidden}")
    return problems


def add_nested_problems(problems: list[str], header: str, nested: list[str]) -> None:
    problems.append(header)
    problems.extend(f"  - {problem}" for problem in nested)


def guard_changed_paths(
    repo_root: Path,
    changed_paths: set[str],
    paths: set[str],
    changed: set[str],
    problems: list[str],
    include_global: bool,
    base_manifest: dict,
    candidate_manifest: dict,
) -> None:
    processed_global_instructions = False
    processed_global_skills: set[str] = set()
    processed_global_hooks: set[str] = set()
    processed_local_instruction_dirs: set[str] = set()
    processed_local_skills: set[str] = set()
    processed_local_hooks: set[str] = set()

    for path in sorted(changed_paths):
        if skip_runtime_path(path):
            continue

        if include_global and path in {GLOBAL_INSTRUCTION_CLAUDE, GLOBAL_INSTRUCTION_CODEX}:
            if processed_global_instructions:
                continue
            processed_global_instructions = True
            item = manifest_item_by_name(candidate_manifest, "instructions", GLOBAL_INSTRUCTION_NAME)
            if manifest_item_is_explicitly_unpaired(item):
                continue
            drift = global_instruction_sync_problems()
            if not drift:
                continue
            counterpart = (
                GLOBAL_INSTRUCTION_CODEX
                if path == GLOBAL_INSTRUCTION_CLAUDE
                else GLOBAL_INSTRUCTION_CLAUDE
            )
            if path_has_change(counterpart, changed_paths):
                add_nested_problems(
                    problems,
                    f"{GLOBAL_INSTRUCTION_CLAUDE} and {GLOBAL_INSTRUCTION_CODEX} are both changed, but the paired instructions still drift:",
                    drift,
                )
            else:
                add_nested_problems(
                    problems,
                    f"{path} changed without synchronized counterpart {counterpart} or an instruction-specific {MANIFEST} exemption:",
                    drift,
                )
        elif include_global and path.startswith("claude/skills/"):
            skill = path.removeprefix("claude/skills/").split("/", 1)[0]
            if skill in processed_global_skills:
                continue
            processed_global_skills.add(skill)
            if manifest_skill_removed(base_manifest, candidate_manifest, skill) and global_skill_files_absent(skill):
                continue
            drift = skill_sync_problems(skill)
            if not drift:
                continue
            item = manifest_item_by_name(candidate_manifest, "skills", skill)
            if manifest_item_is_explicitly_unpaired(item):
                continue
            counterpart = f"codex/skills/{skill}"
            if has_changed_prefix(counterpart, paths, changed):
                add_nested_problems(
                    problems,
                    f"claude/skills/{skill} and {counterpart} are both changed, but the paired skill still drifts:",
                    drift,
                )
            else:
                add_nested_problems(
                    problems,
                    f"claude/skills/{skill} changed without synchronized counterpart {counterpart} or a skill-specific {MANIFEST} exemption:",
                    drift,
                )
        elif include_global and path.startswith("codex/skills/"):
            skill = path.removeprefix("codex/skills/").split("/", 1)[0]
            if skill in processed_global_skills:
                continue
            processed_global_skills.add(skill)
            if manifest_skill_removed(base_manifest, candidate_manifest, skill) and global_skill_files_absent(skill):
                continue
            drift = skill_sync_problems(skill)
            if not drift:
                continue
            item = manifest_item_by_name(candidate_manifest, "skills", skill)
            if manifest_item_is_explicitly_unpaired(item):
                continue
            counterpart = f"claude/skills/{skill}"
            if has_changed_prefix(counterpart, paths, changed):
                add_nested_problems(
                    problems,
                    f"codex/skills/{skill} and {counterpart} are both changed, but the paired skill still drifts:",
                    drift,
                )
            else:
                add_nested_problems(
                    problems,
                    f"codex/skills/{skill} changed without synchronized counterpart {counterpart} or a skill-specific {MANIFEST} exemption:",
                    drift,
                )
        elif include_global and path.startswith("claude/hooks/"):
            hook = path.removeprefix("claude/hooks/")
            if hook in processed_global_hooks:
                continue
            processed_global_hooks.add(hook)
            counterpart = f"codex/hooks/{hook}"
            item = manifest_item_by_name(candidate_manifest, "hooks", hook)
            if manifest_item_is_explicitly_unpaired(item):
                continue
            if not path_has_change(counterpart, changed_paths) and not manifest_item_changed(
                base_manifest,
                candidate_manifest,
                "hooks",
                hook,
            ):
                problems.append(f"claude/hooks/{hook} changed without codex/hooks/{hook} or {MANIFEST}")
        elif include_global and path.startswith("codex/hooks/"):
            hook = path.removeprefix("codex/hooks/")
            if hook in processed_global_hooks:
                continue
            processed_global_hooks.add(hook)
            counterpart = f"claude/hooks/{hook}"
            item = manifest_item_by_name(candidate_manifest, "hooks", hook)
            if manifest_item_is_explicitly_unpaired(item):
                continue
            if not path_has_change(counterpart, changed_paths) and not manifest_item_changed(
                base_manifest,
                candidate_manifest,
                "hooks",
                hook,
            ):
                problems.append(f"codex/hooks/{hook} changed without claude/hooks/{hook} or {MANIFEST}")
        elif (
            include_global
            and path in SYNC_CONFIG_PATHS
            and not manifest_registration_changed(base_manifest, candidate_manifest, path)
        ):
            problems.append(f"{path} changed without a path-specific {MANIFEST} registration update")
        elif Path(path).name in {"CLAUDE.md", "AGENTS.md"}:
            rel_dir = Path(path).parent.as_posix()
            if rel_dir in processed_local_instruction_dirs:
                continue
            processed_local_instruction_dirs.add(rel_dir)
            drift = local_instruction_sync_problems(repo_root, rel_dir)
            if not drift:
                continue
            counterpart = (
                Path(path).with_name("AGENTS.md").as_posix()
                if Path(path).name == "CLAUDE.md"
                else Path(path).with_name("CLAUDE.md").as_posix()
            )
            if path_has_change(counterpart, changed_paths):
                add_nested_problems(
                    problems,
                    f"Project-local instruction files in {rel_dir} are both changed, but still drift:",
                    drift,
                )
            else:
                add_nested_problems(
                    problems,
                    f"Project-local {path} changed without synchronized counterpart {counterpart}:",
                    drift,
                )
        elif path.startswith(".claude/skills/"):
            skill = path.removeprefix(".claude/skills/").split("/", 1)[0]
            skill_key = f"skills/{skill}"
            if skill_key in processed_local_skills:
                continue
            processed_local_skills.add(skill_key)
            drift = local_skill_sync_problems(repo_root, skill)
            doc_drift = local_skill_readme_problems(changed_paths, skill, "skills")
            if not drift:
                if doc_drift:
                    add_nested_problems(
                        problems,
                        f"Project-local .claude/skills/{skill} changed without a local README.org update:",
                        doc_drift,
                    )
                continue
            counterpart = f".codex/skills/{skill}"
            if has_changed_prefix(counterpart, paths, changed):
                add_nested_problems(
                    problems,
                    f"Project-local .claude/skills/{skill} and {counterpart} are both changed, but the paired skill still drifts:",
                    drift + doc_drift,
                )
            else:
                add_nested_problems(
                    problems,
                    f"Project-local .claude/skills/{skill} changed without synchronized counterpart {counterpart}:",
                    drift + doc_drift,
                )
        elif path.startswith(".codex/skills/"):
            skill = path.removeprefix(".codex/skills/").split("/", 1)[0]
            skill_key = f"skills/{skill}"
            if skill_key in processed_local_skills:
                continue
            processed_local_skills.add(skill_key)
            drift = local_skill_sync_problems(repo_root, skill)
            doc_drift = local_skill_readme_problems(changed_paths, skill, "skills")
            if not drift:
                if doc_drift:
                    add_nested_problems(
                        problems,
                        f"Project-local .codex/skills/{skill} changed without a local README.org update:",
                        doc_drift,
                    )
                continue
            counterpart = f".claude/skills/{skill}"
            if has_changed_prefix(counterpart, paths, changed):
                add_nested_problems(
                    problems,
                    f"Project-local .codex/skills/{skill} and {counterpart} are both changed, but the paired skill still drifts:",
                    drift + doc_drift,
                )
            else:
                add_nested_problems(
                    problems,
                    f"Project-local .codex/skills/{skill} changed without synchronized counterpart {counterpart}:",
                    drift + doc_drift,
                )
        elif path.startswith(".claude/programmatic-skills/"):
            skill = path.removeprefix(".claude/programmatic-skills/").split("/", 1)[0]
            skill_key = f"programmatic-skills/{skill}"
            if skill_key in processed_local_skills:
                continue
            processed_local_skills.add(skill_key)
            drift = local_skill_sync_problems(repo_root, skill, "programmatic-skills")
            doc_drift = local_skill_readme_problems(changed_paths, skill, "programmatic-skills")
            if not drift:
                if doc_drift:
                    add_nested_problems(
                        problems,
                        f"Project-local .claude/programmatic-skills/{skill} changed without a local README.org update:",
                        doc_drift,
                    )
                continue
            counterpart = f".codex/programmatic-skills/{skill}"
            if has_changed_prefix(counterpart, paths, changed):
                add_nested_problems(
                    problems,
                    f"Project-local .claude/programmatic-skills/{skill} and {counterpart} are both changed, but the paired skill still drifts:",
                    drift + doc_drift,
                )
            else:
                add_nested_problems(
                    problems,
                    f"Project-local .claude/programmatic-skills/{skill} changed without synchronized counterpart {counterpart}:",
                    drift + doc_drift,
                )
        elif path.startswith(".codex/programmatic-skills/"):
            skill = path.removeprefix(".codex/programmatic-skills/").split("/", 1)[0]
            skill_key = f"programmatic-skills/{skill}"
            if skill_key in processed_local_skills:
                continue
            processed_local_skills.add(skill_key)
            drift = local_skill_sync_problems(repo_root, skill, "programmatic-skills")
            doc_drift = local_skill_readme_problems(changed_paths, skill, "programmatic-skills")
            if not drift:
                if doc_drift:
                    add_nested_problems(
                        problems,
                        f"Project-local .codex/programmatic-skills/{skill} changed without a local README.org update:",
                        doc_drift,
                    )
                continue
            counterpart = f".claude/programmatic-skills/{skill}"
            if has_changed_prefix(counterpart, paths, changed):
                add_nested_problems(
                    problems,
                    f"Project-local .codex/programmatic-skills/{skill} and {counterpart} are both changed, but the paired skill still drifts:",
                    drift + doc_drift,
                )
            else:
                add_nested_problems(
                    problems,
                    f"Project-local .codex/programmatic-skills/{skill} changed without synchronized counterpart {counterpart}:",
                    drift + doc_drift,
                )
        elif path.startswith(".claude/hooks/"):
            hook = path.removeprefix(".claude/hooks/")
            if hook in processed_local_hooks:
                continue
            processed_local_hooks.add(hook)
            counterpart = f".codex/hooks/{hook}"
            if not path_has_change(counterpart, changed_paths):
                problems.append(f"Project-local .claude/hooks/{hook} changed without .codex/hooks/{hook}")
        elif path.startswith(".codex/hooks/"):
            hook = path.removeprefix(".codex/hooks/")
            if hook in processed_local_hooks:
                continue
            processed_local_hooks.add(hook)
            counterpart = f".claude/hooks/{hook}"
            if not path_has_change(counterpart, changed_paths):
                problems.append(f"Project-local .codex/hooks/{hook} changed without .claude/hooks/{hook}")
        elif path == ".claude/settings.json":
            if not path_has_change(".codex/hooks.json", changed_paths):
                problems.append("Project-local .claude/settings.json changed without .codex/hooks.json")
        elif path == ".codex/hooks.json":
            if not path_has_change(".claude/settings.json", changed_paths):
                problems.append("Project-local .codex/hooks.json changed without .claude/settings.json")


def guard_commit() -> None:
    data = read_input_json()
    command = str(tool_input_object(data).get("command") or "")
    paths_by_repo, commit_repos = command_paths_and_commit_repos(command, hook_cwd(data))
    if not commit_repos:
        return

    problems: list[str] = []
    for repo_root in sorted(commit_repos, key=str):
        changed = dirty_paths(repo_root)
        staged = staged_paths(repo_root)
        command_paths = paths_by_repo.get(repo_root, set())
        paths = staged | command_paths
        changed_paths = {path for path in paths if path_has_change(path, changed)}
        if not changed_paths:
            continue

        include_global = same_path(repo_root, ROOT)
        if include_global:
            base_manifest, candidate_manifest = guard_manifests(command_paths, staged, problems)
        else:
            base_manifest, candidate_manifest = {}, {}

        guard_changed_paths(
            repo_root,
            changed_paths,
            paths,
            changed,
            problems,
            include_global,
            base_manifest,
            candidate_manifest,
        )

    if not problems:
        return

    reason = (
        "BLOCKED: AI config sync guard found one-sided Claude/Codex changes.\n\n"
        + "\n".join(problems)
        + "\n\nUpdate the counterpart in this same session. For global dotfiles "
        f"artifacts, stage {MANIFEST} with an explicit status/exemption if the "
        "counterpart should not exist. When updating README.org files, document "
        "the behavior and paths for that README's own tool or project only; do "
        "not document the other agent's behavior in a tool-specific README."
    )
    print(
        json.dumps(
            {
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": reason,
                }
            },
            indent=2,
        )
    )


def load_manifest() -> dict:
    return json.loads(MANIFEST_PATH.read_text())


def add_problem(problems: list[str], message: str) -> None:
    problems.append(message)


def check_symlink(problems: list[str], target: Path, expected: Path, label: str) -> None:
    if not target.is_symlink():
        add_problem(problems, f"Missing live {label} symlink: {target} -> {expected}")
        return
    actual = Path(os.readlink(target))
    if actual != expected:
        add_problem(problems, f"Wrong live {label} symlink: {target} -> {actual}; expected {expected}")


def disabled_skill_records() -> dict:
    if not DISABLED_SKILLS_PATH.exists():
        return {}
    try:
        data = json.loads(DISABLED_SKILLS_PATH.read_text())
    except json.JSONDecodeError as exc:
        return {}
    return data.get("disabled") or {}


def disabled_skill_names() -> set[str]:
    return set(disabled_skill_records())


def check_native_disabled_skills(problems: list[str]) -> None:
    disabled_records = disabled_skill_records()
    disabled = set(disabled_records)
    if not disabled:
        return

    claude_settings = Path.home() / ".claude" / "settings.local.json"
    try:
        claude_data = json.loads(claude_settings.read_text())
    except (OSError, json.JSONDecodeError) as exc:
        add_problem(problems, f"Cannot read live Claude settings.local.json for disabled skills: {exc}")
        claude_data = {}
    overrides = claude_data.get("skillOverrides") or {}
    for name in sorted(disabled):
        if overrides.get(name) != "off":
            add_problem(problems, f"Disabled skill missing Claude skillOverrides off entry: {name}")

    try:
        codex_data = tomllib.loads((ROOT / "codex" / "config.toml").read_text())
    except (OSError, tomllib.TOMLDecodeError) as exc:
        add_problem(problems, f"Cannot read Codex config for disabled skills: {exc}")
        return
    config_entries = ((codex_data.get("skills") or {}).get("config") or [])
    disabled_codex_paths = {
        real_path(path_from_token(str(entry.get("path")), ROOT))
        for entry in config_entries
        if entry.get("enabled") is False and entry.get("path")
    }
    for name in sorted(disabled):
        record = disabled_records.get(name) or {}
        codex_path = record.get("codex_path") or f"codex/skills/{name}/SKILL.md"
        expected = path_from_token(str(codex_path), ROOT)
        if real_path(expected) not in disabled_codex_paths:
            add_problem(problems, f"Disabled skill missing Codex skills.config disabled entry: {name}")


def path_is_inside(path: Path, parent: Path) -> bool:
    try:
        real_path(path).relative_to(real_path(parent))
    except ValueError:
        return False
    return True


def audit_topology(problems: list[str]) -> None:
    forbidden_project_hooks = ROOT / ".codex" / "hooks.json"
    if forbidden_project_hooks.exists() or forbidden_project_hooks.is_symlink():
        add_problem(
            problems,
            "dotfiles/.codex/hooks.json exists; repo-root .codex is project-local, so global Codex hooks must live in codex/hooks.json.",
        )

    live_codex_hooks = Path.home() / ".codex" / "hooks.json"
    if live_codex_hooks.exists() and path_is_inside(live_codex_hooks, ROOT / ".codex"):
        add_problem(
            problems,
            f"Live Codex hooks resolve inside dotfiles/.codex: {live_codex_hooks}; use codex/hooks.json as the global symlink target.",
        )

    allowed_live_symlinks = {
        Path.home() / ".claude": {"CLAUDE.md", "programmatic-skills", "skills"},
        Path.home() / ".codex": {"AGENTS.md", "config.toml", "hooks.json", "programmatic-skills", "rules", "skills"},
    }
    for directory, allowed_names in allowed_live_symlinks.items():
        if not directory.is_dir():
            continue
        for child in directory.iterdir():
            if child.is_symlink() and child.name not in allowed_names:
                add_problem(problems, f"Undocumented live tool-home symlink: {child} -> {os.readlink(child)}")

    project_claude_skills = {
        path.parent.name for path in (ROOT / ".claude" / "skills").glob("*/SKILL.md")
    }
    project_codex_skills = {
        path.parent.name for path in (ROOT / ".codex" / "skills").glob("*/SKILL.md")
    }
    unexpected_project_local = (project_claude_skills | project_codex_skills) - DOTFILES_PROJECT_LOCAL_SKILLS
    for skill in sorted(unexpected_project_local):
        add_problem(
            problems,
            f"unexpected dotfiles project-local skill exists: {skill}; reusable skills belong in claude/skills and codex/skills, not repo-root .claude/.codex.",
        )

    drift = local_instruction_sync_problems(ROOT)
    if drift:
        add_nested_problems(problems, "Dotfiles project instructions are not synchronized:", drift)


def normalized_skill_text(path: Path) -> str:
    text = path.read_text()
    if not text.startswith("---\n"):
        return text
    end = text.find("\n---\n", 4)
    if end < 0:
        return text
    frontmatter = text[4:end].splitlines()
    body = text[end + 5 :]
    kept = []
    for line in frontmatter:
        key = line.split(":", 1)[0].strip() if ":" in line else ""
        if key not in TOOL_SPECIFIC_SKILL_FRONTMATTER:
            kept.append(line)
    return "---\n" + "\n".join(kept) + "\n---\n" + body


def skill_aux_files(skill_dir: Path) -> dict[str, Path]:
    files: dict[str, Path] = {}
    for path in skill_dir.rglob("*"):
        if not path.is_file():
            continue
        rel = path.relative_to(skill_dir).as_posix()
        if rel == "SKILL.md" or path.name == ".DS_Store":
            continue
        if rel.startswith(("digests/", "last-run/", "vetted/")):
            continue
        if "node_modules/" in rel:
            continue
        files[rel] = path
    return files


def command_executable(command: str) -> Path | None:
    try:
        parts = shlex.split(command)
    except ValueError:
        return None
    if not parts:
        return None
    return path_from_token(parts[0], ROOT)


def hook_commands(config: dict) -> list[str]:
    commands: list[str] = []
    for entries in (config.get("hooks") or {}).values():
        for entry in entries:
            for hook in entry.get("hooks") or []:
                command = hook.get("command")
                if command:
                    commands.append(command)
    return commands


def command_mentions_path(command: str, path: Path) -> bool:
    path_text = str(path)
    try:
        parts = shlex.split(command)
    except ValueError:
        return path_text in command
    return any(part == path_text or part == path_text.replace(str(Path.home()), "~") for part in parts) or path_text in command


def audit_instructions(problems: list[str], manifest: dict) -> None:
    instructions = manifest.get("instructions") or []
    item = manifest_item_by_name(manifest, "instructions", GLOBAL_INSTRUCTION_NAME)
    if item is None:
        add_problem(problems, f"Manifest instructions missing: {GLOBAL_INSTRUCTION_NAME}")
    else:
        if item.get("claude") != GLOBAL_INSTRUCTION_CLAUDE:
            add_problem(problems, f"Global instruction manifest has wrong Claude path: {item.get('claude')}")
        if item.get("codex") != GLOBAL_INSTRUCTION_CODEX:
            add_problem(problems, f"Global instruction manifest has wrong Codex path: {item.get('codex')}")
        if not manifest_item_is_paired(item):
            add_problem(problems, f"Global instruction manifest is not marked as a paired artifact: {GLOBAL_INSTRUCTION_NAME}")

    for item in instructions:
        if item.get("codex") == "AGENTS.md":
            add_problem(problems, "Manifest still declares a repo-root AGENTS.md manual counterpart.")

    check_symlink(
        problems,
        Path.home() / ".codex" / "AGENTS.md",
        ROOT / "codex" / "AGENTS.md",
        "Codex global instruction",
    )
    check_symlink(
        problems,
        Path.home() / ".claude" / "CLAUDE.md",
        ROOT / "claude" / "CLAUDE.md",
        "Claude global instruction",
    )
    drift = global_instruction_sync_problems()
    if drift:
        add_nested_problems(problems, "Global instructions are not synchronized:", drift)


def audit_skills(problems: list[str], manifest: dict) -> None:
    manifest_skill_items = {item["name"]: item for item in manifest.get("skills") or []}
    manifest_skills = set(manifest_skill_items)
    claude_skills = {path.parent.name for path in (ROOT / "claude" / "skills").glob("*/SKILL.md")}
    codex_skills = {path.parent.name for path in (ROOT / "codex" / "skills").glob("*/SKILL.md")}

    for skill in sorted(claude_skills - codex_skills):
        item = manifest_skill_items.get(skill)
        if manifest_item_is_explicitly_unpaired(item) and item.get("codex") is None:
            continue
        add_problem(problems, f"Missing Codex skill counterpart: {skill}")
    for skill in sorted(codex_skills - claude_skills):
        item = manifest_skill_items.get(skill)
        if manifest_item_is_explicitly_unpaired(item) and item.get("claude") is None:
            continue
        add_problem(problems, f"Codex skill lacks Claude counterpart or manifest exemption: {skill}")
    for skill in sorted(claude_skills - manifest_skills):
        add_problem(problems, f"Skill missing from manifest: {skill}")
    for skill in sorted(manifest_skills - claude_skills):
        item = manifest_skill_items.get(skill)
        if manifest_item_is_explicitly_unpaired(item) and item.get("claude") is None:
            continue
        add_problem(problems, f"Manifest skill missing from Claude tree: {skill}")

    check_symlink(
        problems,
        Path.home() / ".claude" / "skills",
        ROOT / "claude" / "skills",
        "Claude skills",
    )
    check_symlink(
        problems,
        Path.home() / ".codex" / "skills",
        ROOT / "codex" / "skills",
        "Codex skills",
    )
    check_native_disabled_skills(problems)

    for skill in sorted(claude_skills & codex_skills):
        item = manifest_item_by_name(manifest, "skills", skill)
        if manifest_item_is_explicitly_unpaired(item):
            continue

        claude_skill = ROOT / "claude" / "skills" / skill / "SKILL.md"
        codex_skill = ROOT / "codex" / "skills" / skill / "SKILL.md"
        if normalized_skill_text(claude_skill) != normalized_skill_text(codex_skill):
            add_problem(problems, f"Skill content drift after tool-specific frontmatter normalization: {skill}")

        claude_aux = skill_aux_files(claude_skill.parent)
        codex_aux = skill_aux_files(codex_skill.parent)
        for rel in sorted(set(claude_aux) - set(codex_aux)):
            add_problem(problems, f"Auxiliary skill file only in Claude tree: {skill}/{rel}")
        for rel in sorted(set(codex_aux) - set(claude_aux)):
            add_problem(problems, f"Auxiliary skill file only in Codex tree: {skill}/{rel}")
        for rel in sorted(set(claude_aux) & set(codex_aux)):
            if not filecmp.cmp(claude_aux[rel], codex_aux[rel], shallow=False):
                add_problem(problems, f"Auxiliary skill file drift: {skill}/{rel}")


def audit_hooks(problems: list[str], manifest: dict) -> None:
    manifest_hooks = {item["name"]: item for item in manifest.get("hooks") or []}
    claude_hooks = {path.name for path in (ROOT / "claude" / "hooks").iterdir() if path.is_file()}
    codex_hooks = {path.name for path in (ROOT / "codex" / "hooks").iterdir() if path.is_file()}

    for hook in sorted((claude_hooks | codex_hooks) - set(manifest_hooks)):
        add_problem(problems, f"Hook missing from manifest: {hook}")
    for hook in sorted(set(manifest_hooks) - (claude_hooks | codex_hooks)):
        add_problem(problems, f"Manifest hook missing from both trees: {hook}")

    for name, item in sorted(manifest_hooks.items()):
        status = item.get("status")
        claude = item.get("claude")
        codex = item.get("codex")
        if claude and not (ROOT / claude).exists():
            add_problem(problems, f"Manifest Claude hook path missing: {claude}")
        if codex and not (ROOT / codex).exists():
            add_problem(problems, f"Manifest Codex hook path missing: {codex}")
        if manifest_item_is_paired(item) and not (claude and codex):
            add_problem(problems, f"Paired hook lacks both sides in manifest: {name}")

    claude_settings = json.loads((Path.home() / ".claude" / "settings.json").read_text())
    codex_hooks_json = json.loads((ROOT / "codex" / "hooks.json").read_text())
    claude_commands = hook_commands(claude_settings)
    codex_commands = hook_commands(codex_hooks_json)

    for label, commands in (("Claude", claude_commands), ("Codex", codex_commands)):
        for command in commands:
            executable = command_executable(command)
            if executable is None or not executable.exists():
                add_problem(problems, f"{label} hook command executable is missing: {command}")

    for name, item in sorted(manifest_hooks.items()):
        if not manifest_item_is_registered_pair(item):
            continue
        claude_path = ROOT / item["claude"]
        codex_path = ROOT / item["codex"]
        if not any(command_mentions_path(command, claude_path) for command in claude_commands):
            add_problem(problems, f"Ported Claude hook is not registered in ~/.claude/settings.json: {name}")
        if not any(command_mentions_path(command, codex_path) for command in codex_commands):
            add_problem(problems, f"Ported Codex hook is not registered in codex/hooks.json: {name}")


def audit_registrations(problems: list[str], manifest: dict) -> None:
    check_symlink(
        problems,
        Path.home() / ".codex" / "config.toml",
        ROOT / "codex" / "config.toml",
        "Codex config",
    )
    check_symlink(
        problems,
        Path.home() / ".codex" / "hooks.json",
        ROOT / "codex" / "hooks.json",
        "Codex hooks",
    )
    check_symlink(
        problems,
        Path.home() / ".codex" / "rules",
        ROOT / "codex" / "rules",
        "Codex rules",
    )

    config = tomllib.loads((ROOT / "codex" / "config.toml").read_text())
    if "project_doc_fallback_filenames" in config:
        add_problem(
            problems,
            "codex/config.toml still configures project_doc_fallback_filenames; project Codex instructions now come from AGENTS.md.",
        )
    if not config.get("features", {}).get("hooks"):
        add_problem(problems, "codex/config.toml does not enable features.hooks.")

    registration_paths = {item.get("path") for item in manifest.get("registrations") or []}
    for expected in (
        "codex/AGENTS.md",
        "~/.claude/settings.json",
        "codex/hooks.json",
        "codex/config.toml",
        "codex/bin/install-skills.sh",
        "codex/rules/default.rules",
    ):
        if expected not in registration_paths:
            add_problem(problems, f"Manifest registrations missing: {expected}")


def audit() -> int:
    problems: list[str] = []
    if not MANIFEST_PATH.exists():
        print(f"Missing manifest: {MANIFEST}")
        return 1

    manifest = load_manifest()
    audit_topology(problems)
    audit_instructions(problems, manifest)
    audit_skills(problems, manifest)
    audit_hooks(problems, manifest)
    audit_registrations(problems, manifest)

    if problems:
        print("AI config sync audit failed:")
        for problem in problems:
            print(f"- {problem}")
        return 1

    print("AI config sync audit passed.")
    return 0


def iter_project_claude_files(search_root: Path) -> Iterable[Path]:
    for current, dirs, files in os.walk(search_root):
        dirs[:] = [
            item
            for item in dirs
            if item
            not in {
                ".git",
                ".hg",
                ".svn",
                "node_modules",
                ".venv",
                "venv",
                "__pycache__",
            }
        ]
        if "CLAUDE.md" in files:
            yield Path(current) / "CLAUDE.md"


def skip_project_instruction_migration(path: Path) -> bool:
    return same_path(path, ROOT / GLOBAL_INSTRUCTION_CLAUDE)


def migrate_project_instructions(argv: list[str]) -> int:
    roots = [path_from_token(arg, Path.cwd()) for arg in argv] if argv else [ROOT]
    created: list[Path] = []
    skipped_existing: list[Path] = []
    skipped_nested: list[Path] = []
    skipped_not_git: list[Path] = []

    for search_root in roots:
        if search_root.is_file():
            candidates = [search_root]
        else:
            candidates = list(iter_project_claude_files(search_root))

        for claude_path in candidates:
            repo_root = git_root_for_path(claude_path)
            if repo_root is None:
                skipped_not_git.append(claude_path)
                continue
            try:
                rel = claude_path.relative_to(repo_root).as_posix()
            except ValueError:
                skipped_nested.append(claude_path)
                continue
            if skip_project_instruction_migration(claude_path):
                continue

            codex_path = claude_path.with_name("AGENTS.md")
            if codex_path.exists():
                skipped_existing.append(codex_path)
                continue

            codex_path.write_text(codex_project_instruction_text_from_claude(claude_path))
            created.append(codex_path)

    for path in created:
        print(f"Created {path}")
    for path in skipped_existing:
        print(f"Skipped existing {path}")
    for path in skipped_nested:
        print(f"Skipped nested non-root {path}")
    for path in skipped_not_git:
        print(f"Skipped non-git {path}")

    if not created:
        print("No missing project AGENTS.md files created.")
    return 0


def main() -> int:
    mode = sys.argv[1] if len(sys.argv) > 1 else ""
    if mode == "remind-claude":
        remind_claude()
        return 0
    if mode == "remind-codex":
        remind_codex()
        return 0
    if mode == "guard-commit":
        guard_commit()
        return 0
    if mode == "audit":
        return audit()
    if mode == "migrate-project-instructions":
        return migrate_project_instructions(sys.argv[2:])
    usage()
    return 2


if __name__ == "__main__":
    raise SystemExit(main())
