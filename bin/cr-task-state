#!/usr/bin/env python3
"""cr-task-state — one-screen state map for a CR task, with divergence banner.

Answers "which branch / run / rubric revision is live for this task?"
deterministically, so a fresh session never resolves it by trial-and-error.

Sources scanned (all read-only):
  * remote branches whose name mentions the slug or its numeric id token
  * branches linked from the task's GitHub issue comments (tree/blob URLs)
  * each candidate branch's last commit touching tasks/<slug>/, its rubric
    criterion-id fingerprint, and its pinned basic_info.json taigaLink
  * the working tree's own branch / rubric / taigaLink / dirty files
  * the issue thread: newest comment, plus every Taiga job UUID mentioned
    (runs launched from unpushed trees still surface here — comments are the
    only place they exist)

Divergence banners fire when: branch tips carry different rubric fingerprints;
the newest task-touching tip is not the working tree's branch; the thread has
activity newer than the working tree's lineage; or comments mention Taiga jobs
that no branch pins.

Usage: cr-task-state [<slug>] [--repo OWNER/NAME] [--hook] [--no-fetch]
  <slug>      defaults to the worktree directory's basename
  --hook      compact, never-fail mode for the SessionStart banner
  --no-fetch  skip `git fetch` (offline; uses whatever refs are local)
"""

from __future__ import annotations

import argparse
import hashlib
import json
import re
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

DEFAULT_REPO = "trajectory-labs-pbc/reasoning-tasks"
UUID_RE = re.compile(r"\b[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\b")


def run(cmd: list[str], cwd: str | None = None, timeout: int = 30) -> str:
    try:
        out = subprocess.run(
            cmd, cwd=cwd, capture_output=True, text=True, timeout=timeout
        )
        return out.stdout if out.returncode == 0 else ""
    except (subprocess.TimeoutExpired, OSError):
        return ""


def git(args: list[str], timeout: int = 30) -> str:
    return run(["git", *args], timeout=timeout)


def parse_iso(s: str) -> datetime | None:
    try:
        return datetime.fromisoformat(s.replace("Z", "+00:00")).astimezone(timezone.utc)
    except ValueError:
        return None


def rubric_fingerprint(blob: str) -> tuple[str, int]:
    """Fingerprint = short hash of the sorted rubric criterion ids."""
    ids = sorted(set(re.findall(r"^\|\s*`([a-z0-9_]+)`", blob, re.M)))
    if not ids:
        return ("-", 0)
    digest = hashlib.sha1(",".join(ids).encode()).hexdigest()[:6]
    return (digest, len(ids))


def taiga_job_of(basic_info_blob: str) -> str:
    try:
        link = json.loads(basic_info_blob).get("taigaLink") or ""
    except (json.JSONDecodeError, AttributeError):
        return "-"
    m = UUID_RE.search(link)
    return m.group(0)[:8] if m else "-"


def find_task_dir(ref: str, slug: str) -> str | None:
    """Resolve the task's dir at a ref, tolerating dir-name prefixes that differ
    from the issue slug (`grantmaking-<slug>`, `cr-<slug>`, `<num>-<slug>`).

    The literal `tasks/<slug>/` match was the 2026-07-04 silent failure: prefixed
    dirs read as "no branches touch this task", so audits fell back to whatever
    stale branch carried the bare-slug dir. Returns the full `tasks/<dir>` path."""
    entries = [e for e in git(["ls-tree", "--name-only", ref, "tasks/"]).splitlines()
               if e.startswith("tasks/")]
    bases = {e: e.split("/", 1)[1] for e in entries}
    for e, b in bases.items():          # exact
        if b == slug:
            return e
    for e, b in bases.items():          # prefixed: <prefix>-<slug>
        if b.endswith("-" + slug):
            return e
    for e, b in bases.items():          # slug as substring (last resort)
        if slug in b:
            return e
    return None


def branch_facts(ref: str, slug: str) -> dict | None:
    """Last task-touching commit + rubric fingerprint + taigaLink at a ref."""
    d = find_task_dir(ref, slug)
    if not d:
        return None
    line = git(
        ["log", "-1", "--format=%H\x1f%aI\x1f%an\x1f%s", ref, "--", f"{d}/"]
    ).strip()
    if not line:
        return None
    sha, date, author, subject = line.split("\x1f")
    fp, n = rubric_fingerprint(git(["show", f"{ref}:{d}/grading/rubric.md"]))
    job = taiga_job_of(git(["show", f"{ref}:{d}/basic_info.json"]))
    return {
        "ref": ref, "sha": sha[:10], "date": date, "author": author,
        "subject": subject[:64], "fp": fp, "ncrit": n, "job": job,
        "dir": d.split("/", 1)[1],
    }


def pr_facts(issue_number: int | None, slug: str, repo: str) -> dict | None:
    """The open PR whose branch is this task's canonical lineage. Prefer a PR that
    closes the issue; fall back to a unique PR whose branch/title carries the slug.
    The team convention (Slack 2026-07-04) is that the PR branch is the source of
    truth, so this is the branch every audit/edit must target."""
    if not repo:
        return None
    raw = run(["gh", "pr", "list", "--repo", repo, "--state", "open", "--limit", "300",
               "--json", "number,headRefName,url,title,closingIssuesReferences"], timeout=30)
    try:
        prs = json.loads(raw)
    except (json.JSONDecodeError, TypeError):
        return None
    if issue_number is not None:
        for pr in prs:
            if any((r or {}).get("number") == issue_number
                   for r in pr.get("closingIssuesReferences") or []):
                return {"number": pr["number"], "branch": pr["headRefName"], "url": pr["url"]}
    hits = [pr for pr in prs
            if slug in (pr.get("headRefName") or "") or slug == (pr.get("title") or "").strip()]
    if len(hits) == 1:
        return {"number": hits[0]["number"], "branch": hits[0]["headRefName"],
                "url": hits[0]["url"]}
    return None


def sweep_path_branches(owner: str, repo_name: str, slug: str) -> set[str]:
    """Every remote branch with ANY commit touching tasks/<slug>/ (server-side)."""
    found: set[str] = set()
    cursor = "null"
    for _page in range(15):
        raw = run(
            ["gh", "api", "graphql", "-f", "query="
             '{repository(owner:"%s",name:"%s"){refs(refPrefix:"refs/heads/",'
             "first:100,after:%s){pageInfo{hasNextPage endCursor}"
             'nodes{name target{...on Commit{history(first:1,path:"tasks/%s")'
             "{nodes{committedDate}}}}}}}}" % (owner, repo_name, cursor, slug)],
            timeout=25)
        try:
            refs = json.loads(raw)["data"]["repository"]["refs"]
        except (json.JSONDecodeError, KeyError, TypeError):
            break
        for n in refs["nodes"]:
            hist = ((n.get("target") or {}).get("history") or {}).get("nodes") or []
            if hist:
                found.add(n["name"])
        if not refs["pageInfo"]["hasNextPage"]:
            break
        cursor = json.dumps(refs["pageInfo"]["endCursor"])
    return found


def issue_facts(slug: str, repo: str) -> dict:
    """Issue number, newest comment, branch links and job UUIDs in the thread."""
    facts = {"number": None, "comments": [], "branches": set(), "jobs": []}
    listing = run(
        ["gh", "issue", "list", "--repo", repo, "--search", f"{slug} in:title",
         "--state", "all", "--json", "number,title"], timeout=25)
    try:
        items = [i for i in json.loads(listing) if i["title"].strip() == slug] or json.loads(listing)
        facts["number"] = items[0]["number"] if items else None
    except (json.JSONDecodeError, IndexError, KeyError):
        return facts
    if not facts["number"]:
        return facts
    raw = run(
        ["gh", "issue", "view", str(facts["number"]), "--repo", repo,
         "--json", "comments,body"], timeout=25)
    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        return facts
    texts = [data.get("body", "")]
    for c in data.get("comments", []):
        facts["comments"].append({
            "at": c["createdAt"], "who": c["author"]["login"],
            "head": c["body"].split("\n", 1)[0][:88],
        })
        texts.append(c["body"])
    for t in texts:
        for m in re.finditer(rf"/(?:tree|blob)/([^\s)\"'#]+?)/tasks/{re.escape(slug)}", t):
            facts["branches"].add(m.group(1))
        env_uuids = set(re.findall(r"environmentId=([0-9a-f-]{36})", t))
        facts["jobs"].extend(u for u in UUID_RE.findall(t) if u not in env_uuids)
    # de-dup jobs, newest-mention-last order preserved
    seen: set[str] = set()
    facts["jobs"] = [j for j in facts["jobs"] if not (j in seen or seen.add(j))]
    return facts


def main() -> int:
    ap = argparse.ArgumentParser()
    ap.add_argument("slug", nargs="?")
    ap.add_argument("--repo", default=DEFAULT_REPO)
    ap.add_argument("--hook", action="store_true")
    ap.add_argument("--no-fetch", action="store_true")
    ap.add_argument("--gate", action="store_true",
                    help="machine verdict for the QA-entry gate: print one "
                         "GATE READY|BLOCK line and exit 0 (ready) / 3 (block).")
    args = ap.parse_args()

    if args.hook:
        # A session-start banner must never hang the hook: hard 40s ceiling.
        import signal

        def _bail(signum, frame):
            print("task-state: timed out (network?) — run `cr-task-state` manually")
            raise SystemExit(0)

        signal.signal(signal.SIGALRM, _bail)
        signal.alarm(40)

    root = git(["rev-parse", "--show-toplevel"]).strip()
    if not root:
        print("cr-task-state: not in a git repo", file=sys.stderr)
        return 0 if args.hook else 1
    slug = args.slug or Path(root).name
    id_token = next((t for t in slug.split("-") if t.isdigit()), None)

    # --- candidate branches: by name, then by issue-comment links -----------
    heads = git(["ls-remote", "--heads", "origin"], timeout=40)
    by_name = set()
    for line in heads.splitlines():
        name = line.split("refs/heads/", 1)[-1]
        if slug in name or (id_token and re.search(rf"(?<![0-9]){id_token}(?![0-9])", name)):
            by_name.add(name)

    # Exhaustive server-side sweep: every remote branch, filtered by whether it
    # has ANY commit touching tasks/<slug>/ (GraphQL history(path:)). Task work
    # can live on a branch that carries no slug token and that nothing links
    # (2026-07-03: the adj lineage sat on pushed `ryan-qa-06-28`; name-and-link
    # discovery missed it and the state map wrongly implied unpushed work).
    owner, repo_name = args.repo.split("/", 1)
    # The full sweep costs ~1 min on a 1200-branch repo, too slow for the
    # SessionStart banner, so it is cached (6h). Hook mode uses a fresh cache
    # or, failing that, fast name+link discovery now plus a detached self-run
    # that refreshes the cache for the next invocation.
    cache = Path.home() / ".cache" / "cr-task-state" / f"{args.repo.replace('/', '-')}-{slug}.json"
    cached_branches: set[str] | None = None
    try:
        blob = json.loads(cache.read_text())
        import time
        if time.time() - blob["ts"] < 6 * 3600:
            cached_branches = set(blob["branches"])
    except (OSError, ValueError, KeyError):
        pass

    stale_note = ""
    if args.hook and cached_branches is None:
        subprocess.Popen(  # refresh cache for next time; this run stays fast
            [str(Path(__file__).resolve()), slug, "--repo", args.repo, "--no-fetch"],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
            start_new_session=True)
        stale_note = ("note: branch map from fast discovery only (name matches + "
                      "thread links); exhaustive sweep refreshing in background — "
                      "re-run `cr-task-state` in ~1 min for the complete map")

    path_branches: set[str] = set()
    if cached_branches is not None:
        path_branches = cached_branches
    elif not args.hook and not args.gate:
        # --gate runs on every QA-entry tool call, so it must stay fast: rely on
        # name/link discovery + the resolved PR branch, skip the ~1min sweep.
        path_branches = sweep_path_branches(owner, repo_name, slug)
        try:
            import time
            cache.parent.mkdir(parents=True, exist_ok=True)
            cache.write_text(json.dumps({"ts": time.time(), "branches": sorted(path_branches)}))
        except OSError:
            pass
    issue = issue_facts(slug, args.repo)
    pr = pr_facts(issue["number"], slug, args.repo)
    pr_branches = {pr["branch"]} if pr else set()
    candidates = sorted(by_name | issue["branches"] | path_branches | pr_branches)

    if candidates and not args.no_fetch:
        git(["fetch", "--quiet", "origin",
             *[f"+refs/heads/{b}:refs/remotes/origin/{b}" for b in candidates]],
            timeout=90)

    rows = []
    for b in candidates:
        f = branch_facts(f"origin/{b}", slug)
        if f:
            f["ref"] = b
            rows.append(f)
    rows.sort(key=lambda r: parse_iso(r["date"]) or datetime.min.replace(tzinfo=timezone.utc),
              reverse=True)

    # --- canonical PR lineage + run provenance -------------------------------
    MINDT = datetime.min.replace(tzinfo=timezone.utc)
    # A migration/port/rename/scaffold commit can give a STALE copy of the task a
    # newer commit date than the live PR branch (2026-07-04: pablo/forethought's
    # old 12-criterion copy re-dated by a "Port agent-c prep branch" commit falsely
    # superseded PR #464's hardened 10-criterion rubric). Exclude those subjects so
    # the supersession flag means "newer WORK", not "newer copy".
    MIGRATION_RE = re.compile(r"port|migrat|rename|scaffold|bulk|prep branch", re.I)
    pr_row = next((r for r in rows if pr and r["ref"] == pr["branch"]), None)
    superseder = None
    if pr_row:
        for r in rows:
            if (r["ref"] != pr["branch"] and r["fp"] != "-" and r["fp"] != pr_row["fp"]
                    and (parse_iso(r["date"]) or MINDT) > (parse_iso(pr_row["date"]) or MINDT)
                    and not MIGRATION_RE.search(r["subject"] or "")):
                superseder = r
                break
    newest_job = issue["jobs"][-1][:8] if issue["jobs"] else None
    if not pr_row:
        prov = ("n/a", "")
    elif pr_row["job"] == "-":
        prov = ("unknown", "PR branch pins no taigaLink")
    elif newest_job and newest_job != pr_row["job"]:
        prov = ("drifted", f"newest thread run {newest_job} not the PR-pinned {pr_row['job']}")
    else:
        prov = ("matched", "")

    # --- gate mode: one machine line + exit code (0 ready / 3 block) ----------
    if args.gate:
        if not pr:
            verdict, reason = "BLOCK", ("no open PR resolves this issue — attach a "
                                        "canonical PR before QA")
        elif not pr_row:
            verdict, reason = "BLOCK", (f"PR #{pr['number']} branch {pr['branch']} "
                                        "carries no task dir")
        elif superseder:
            verdict, reason = "BLOCK", (f"PR #{pr['number']} ({pr['branch']}) superseded by "
                                        f"non-PR branch {superseder['ref']} "
                                        f"({superseder['date'][:10]}) — reconcile onto the PR "
                                        "before QA")
        else:
            verdict = "READY"
            reason = f"canonical PR #{pr['number']} · {pr['branch']}"
            if prov[0] not in ("matched", "n/a"):
                reason += f" · provenance {prov[0]}: {prov[1]}"
        print(f"GATE {verdict}: {slug} — {reason}")
        return 0 if verdict == "READY" else 3

    # --- working tree --------------------------------------------------------
    wt_branch = git(["branch", "--show-current"]).strip() or "(detached)"
    wt = None
    if (Path(root) / "tasks" / slug).is_dir():
        fp, n = rubric_fingerprint(
            (Path(root) / "tasks" / slug / "grading" / "rubric.md").read_text()
            if (Path(root) / "tasks" / slug / "grading" / "rubric.md").exists() else "")
        bi = Path(root) / "tasks" / slug / "basic_info.json"
        wt = {"fp": fp, "ncrit": n,
              "job": taiga_job_of(bi.read_text()) if bi.exists() else "-"}

    # --- report --------------------------------------------------------------
    out: list[str] = []
    hdr = f"task-state: {slug}"
    if issue["number"]:
        hdr += f" · issue #{issue['number']}"
    out.append(hdr)

    if pr:
        line = f"→ canonical PR #{pr['number']} · {pr['branch']}"
        if pr_row:
            line += f"  [provenance: {prov[0]}]"
        else:
            line += "  ⚠️ branch carries NO task dir"
        out.append(line)
    else:
        out.append("→ canonical PR: NONE — no open PR resolves this issue")

    if rows:
        out.append(f" {'branch':39} {'last task commit':25} {'rubric':12} {'taigaLink':9}")
        for r in rows:
            mark = "*" if pr and r["ref"] == pr["branch"] else " "
            out.append(
                f"{mark}{r['ref']:39} {r['date'][:16]:25} "
                f"{r['fp']}({r['ncrit']}){'':<4} {r['job']:9}  {r['author']}: {r['subject']}")
        if pr:
            out.append("  (* = canonical PR branch — the version to audit/edit)")
    else:
        out.append(f"no remote branches carry a dir for {slug} (tried prefixes too)")
    if wt:
        out.append(
            f"{'[working tree] ' + wt_branch:40} {'':25} "
            f"{wt['fp']}({wt['ncrit']}){'':<4} {wt['job']:9}")
    elif rows:
        out.append(f"[working tree] {wt_branch} — tasks/{slug}/ NOT checked out here")

    if issue["comments"]:
        newest = issue["comments"][-1]
        out.append(f"thread: {len(issue['comments'])} comments; newest "
                   f"{newest['at'][:16]} {newest['who']}: {newest['head']}")

    # --- divergence banners ---------------------------------------------------
    warns: list[str] = []
    fps = {r["fp"] for r in rows if r["fp"] != "-"}
    if len(fps) > 1:
        warns.append(f"{len(fps)} distinct rubric variants across branches — "
                     "identify the live lineage before any audit/edit")
    if rows and wt:
        if wt["fp"] not in fps and wt["fp"] != "-":
            warns.append("working-tree rubric matches NO remote branch (local variant?)")
        if rows[0]["fp"] != wt["fp"]:
            warns.append(f"newest lineage is {rows[0]['ref']} "
                         f"({rows[0]['date'][:10]}) — NOT what the working tree has")
    if rows and issue["comments"]:
        newest_c = parse_iso(issue["comments"][-1]["at"])
        newest_b = max(parse_iso(r["date"]) for r in rows)
        if newest_c and newest_b and newest_c > newest_b:
            warns.append("thread activity is newer than every branch's last task "
                         "commit — read the newest comments before trusting git state")
    pinned = {r["job"] for r in rows if r["job"] != "-"} | ({wt["job"]} if wt else set())
    stray = [j[:8] for j in issue["jobs"] if j[:8] not in pinned][-4:]
    if stray:
        warns.append(f"thread mentions Taiga job(s) no branch pins: {', '.join(stray)} "
                     "— check the thread for which task state each evaluated")
    if not pr:
        warns.append("no open PR resolves this issue — canonical lineage UNSET "
                     "(team convention: the PR branch is the source of truth)")
    if superseder:
        warns.append(f"canonical PR #{pr['number']} ({pr['branch']}) is SUPERSEDED by non-PR "
                     f"branch {superseder['ref']} ({superseder['date'][:10]}) — reconcile onto "
                     "the PR before any audit/edit")
    if pr_row and prov[0] in ("drifted", "unknown"):
        warns.append(f"run provenance {prov[0]}: {prov[1]} — rerun from the PR branch or name "
                     "the ref in the QA comment")

    for w in warns:
        out.append(f"⚠️  {w}")
    if not warns and rows:
        out.append("✓ single coherent lineage" + (f"; canonical = PR #{pr['number']}" if pr else ""))
    if stale_note:
        out.append(stale_note)

    print("\n".join(out))
    return 0


if __name__ == "__main__":
    sys.exit(main())
