  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.stafforini.personal-updates.delayed</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/pablostafforini/My Drive/dotfiles/bin/personal-updates</string>
    <string>delayed</string>
    <string>--min-age-days</string>
    <string>7</string>
