#!/usr/bin/env python3
"""Refresh a Google Workspace OAuth token and update the matching env var.

This helper intentionally prints only status metadata, never token values.
"""

from pathlib import Path
import argparse
import os
import sys

from google_auth_oauthlib.flow import InstalledAppFlow


TOKEN_VARS = {
    "epoch": "GOOGLE_WORKSPACE_REFRESH_TOKEN",
    "personal": "GOOGLE_WORKSPACE_REFRESH_TOKEN_PERSONAL",
}

SCOPES = {
    "epoch": [
        "https://www.googleapis.com/auth/gmail.modify",
        "https://www.googleapis.com/auth/calendar",
        "https://www.googleapis.com/auth/drive",
        "https://www.googleapis.com/auth/documents",
        "https://www.googleapis.com/auth/spreadsheets",
    ],
    "personal": [
        "https://www.googleapis.com/auth/gmail.modify",
        "https://www.googleapis.com/auth/spreadsheets",
    ],
}


def update_env_file(var, value, path):
    text = path.read_text() if path.exists() else ""
    new_line = f'export {var}="{value}"\n'
    lines = text.splitlines(keepends=True)
    for i, line in enumerate(lines):
        if line.startswith(f"export {var}="):
            lines[i] = new_line
            break
    else:
        if text and not text.endswith("\n"):
            lines.append("\n")
        lines.append(new_line)
    path.write_text("".join(lines))


def main():
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--account", choices=sorted(TOKEN_VARS), required=True)
    parser.add_argument("--port", type=int, default=8080)
    args = parser.parse_args()

    var = TOKEN_VARS[args.account]
    flow = InstalledAppFlow.from_client_config(
        {
            "installed": {
                "client_id": os.environ["GOOGLE_WORKSPACE_CLIENT_ID"],
                "client_secret": os.environ["GOOGLE_WORKSPACE_CLIENT_SECRET"],
                "redirect_uris": ["http://localhost"],
                "auth_uri": "https://accounts.google.com/o/oauth2/auth",
                "token_uri": "https://oauth2.googleapis.com/token",
            }
        },
        SCOPES[args.account],
    )
    creds = flow.run_local_server(port=args.port, open_browser=True)
    secrets = Path.home() / "My Drive" / "dotfiles" / "shell" / ".zshenv-secrets"
    update_env_file(var, creds.refresh_token, secrets)
    print(f"Updated {var} in {secrets}", file=sys.stderr)


if __name__ == "__main__":
    main()
