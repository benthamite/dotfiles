#!/usr/bin/env python3
"""Compatibility wrapper for `cr-taiga run`."""

from __future__ import annotations

import json
import os
import sys
from pathlib import Path


def forwarded(argv: list[str]) -> list[str]:
    target = str(Path(__file__).resolve().with_name("cr-taiga"))
    return [target, "run", *argv]


def main() -> int:
    args = list(sys.argv[1:])
    if "--print-forwarded-command" in args:
        args.remove("--print-forwarded-command")
        print(json.dumps(forwarded(args)))
        return 0
    os.execv(forwarded(args)[0], forwarded(args))
    return 127


if __name__ == "__main__":
    raise SystemExit(main())
