#!/bin/bash

# Define the function to sync mail using mbsync
sync_channel() {
    channel="$1"
    echo "Starting sync for $channel"
    mbsync -q "$channel"
    echo "Finished sync for $channel"
}

export -f sync_channel

# Check if the first argument is 'include-gmail-all'
include_gmail_all=false
if [ "$1" == "include-gmail-all" ]; then
    include_gmail_all=true
fi

# Generate a list of mbsync channels, excluding epoch (handled by gmail-maildir-sync)
if [ "$include_gmail_all" = true ]; then
    channels=$(grep '^Channel ' ~/.mbsyncrc | awk '{print $2}' | grep -v '^epoch-' | sort -u)
else
    channels=$(grep '^Channel ' ~/.mbsyncrc | awk '{print $2}' | grep -v '^epoch-' | grep -v -- '-all$' | sort -u)
fi

# Decrypt the IMAP password once to a secure temp file so the parallel mbsync
# jobs below don't race on the GPG keyring lock (otherwise each channel's
# PassCmd invokes gpg concurrently and some emit "gpg: lockfile disappeared").
# mbsync-passcmd reads from this file when MBSYNC_PASSFILE is set.
MBSYNC_PASSFILE=$(mktemp -t mbsync-pass.XXXXXX)
chmod 600 "$MBSYNC_PASSFILE"
trap 'rm -f "$MBSYNC_PASSFILE"' EXIT
gpg --quiet --decrypt "$HOME/.password-store/auth-sources/mbsync/password.gpg" \
    > "$MBSYNC_PASSFILE"
export MBSYNC_PASSFILE

# Run gmail-maildir-sync in background (no GPG needed), mbsync in foreground
# (mbsync needs GPG/pinentry which requires a TTY)
gmail-maildir-sync sync &
GMAIL_PID=$!

echo "$channels" | parallel --will-cite sync_channel

wait $GMAIL_PID
