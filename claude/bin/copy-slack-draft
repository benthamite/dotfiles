#!/usr/bin/env python3
"""Copy a Slack draft to the Emacs kill ring and optionally prefill a reply."""

import argparse
import json
import subprocess
import sys
from pathlib import Path


def run_emacs_eval(expr: str) -> None:
    result = subprocess.run(
        ["emacsclient", "--eval", expr],
        check=False,
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        detail = (result.stderr or result.stdout).strip()
        raise RuntimeError(detail or "emacsclient failed")


def elisp_string(value: str) -> str:
    # JSON strings are valid enough Elisp string literals for paths and URLs.
    return json.dumps(value)


def copy_to_kill_ring(path: Path) -> None:
    expr = (
        "(with-temp-buffer "
        f"(insert-file-contents {elisp_string(str(path))}) "
        "(kill-new (buffer-string)))"
    )
    run_emacs_eval(expr)


def prefill_slack_reply(permalink: str, path: Path) -> None:
    expr = (
        "(progn "
        "(require (quote cl-lib)) "
        "(require (quote slack-team) nil t) "
        "(unless (fboundp (quote slack-browse-url)) "
        "  (require (quote slack) nil t)) "
        "(unless (fboundp (quote slack-browse-url)) "
        '(error "slack-browse-url is not available")) '
        "(let* ((info (slack-permalink-to-info "
        f"{elisp_string(permalink)})) "
        "(team-domain (plist-get info :team-domain)) "
        "(room-id (plist-get info :room-id)) "
        "(ts (plist-get info :ts)) "
        "(thread-ts (plist-get info :thread-ts)) "
        "(team (or (slack-team-find-by-domain team-domain) "
        "          (--find (or (equal team-domain (oref it name)) "
        "                      (and (string= team-domain \"epochai\") "
        "                           (equal (oref it name) \"Epoch AI\"))) "
        "                  (hash-table-values slack-teams-by-token))))) "
        "(unless team "
        "  (error \"No registered Slack team for %s\" team-domain)) "
        "(unless (slack-team-connectedp team) "
        "  (slack-start team) "
        "  (let ((deadline (+ (float-time) 20))) "
        "    (while (and (not (slack-team-connectedp team)) "
        "                (< (float-time) deadline)) "
        "      (accept-process-output nil 0.25)))) "
        "(let ((room (slack-room-find room-id team))) "
        "  (unless room "
        "    (error \"Slack room %s is not loaded for team %s\" "
        "           room-id (oref team name))) "
        "  (slack-open-message team room ts thread-ts ts nil))) "
        "(sit-for 1.5) "
        "(unless (fboundp (quote slack-thread-reply)) "
        "  (require (quote slack-message-buffer) nil t)) "
        "(unless (fboundp (quote slack-thread-reply)) "
        '(error "slack-thread-reply is not available")) '
        "(call-interactively (quote slack-thread-reply)) "
        "(sit-for 0.5) "
        f"(insert-file-contents {elisp_string(str(path))}) "
        "nil)"
    )
    run_emacs_eval(expr)


def main() -> int:
    parser = argparse.ArgumentParser(
        description=(
            "Copy a Slack draft to the Emacs kill ring and prefill its reply."
        )
    )
    parser.add_argument("--file", required=True, help="Path to the draft text file")
    parser.add_argument(
        "--permalink",
        help="Slack permalink to open and prefill in Emacs after copying the draft",
    )
    parser.add_argument(
        "--no-open",
        action="store_true",
        help=(
            "Only copy the draft; do not open or prefill Slack. "
            "Useful for smoke tests."
        ),
    )
    args = parser.parse_args()

    draft_path = Path(args.file).expanduser()
    if not draft_path.exists():
        sys.stderr.write(f"ERROR: draft file does not exist: {draft_path}\n")
        return 2
    if not draft_path.is_file():
        sys.stderr.write(f"ERROR: draft path is not a file: {draft_path}\n")
        return 2
    text = draft_path.read_text()
    if not text.strip():
        sys.stderr.write(f"ERROR: draft file is empty: {draft_path}\n")
        return 2
    if not args.no_open and not args.permalink:
        sys.stderr.write("ERROR: --permalink is required unless --no-open is used\n")
        return 2

    try:
        copy_to_kill_ring(draft_path)
    except RuntimeError as exc:
        sys.stderr.write(f"ERROR: failed to copy draft to Emacs kill ring: {exc}\n")
        return 1
    print("Copied draft to Emacs kill ring")

    if args.no_open:
        return 0

    try:
        prefill_slack_reply(args.permalink, draft_path)
    except RuntimeError as exc:
        sys.stderr.write(
            "ERROR: failed to open Slack reply composer and insert draft in "
            f"Emacs: {exc}\n"
        )
        return 1
    print("Opened Slack reply composer and inserted draft in Emacs")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
